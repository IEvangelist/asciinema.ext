{
  "name": "asciinema",
  "displayName": "asciinema.casts",
  "description": "Preview and play asciinema .cast terminal recordings directly in VS Code.",
  "version": "0.2.0",
  "publisher": "davidpine-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "asciinema",
    "cast",
    "terminal",
    "recording",
    "player",
    "asciicast",
    "preview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/IEvangelist/asciinema.ext"
  },
  "homepage": "https://github.com/IEvangelist/asciinema.ext#readme",
  "bugs": {
    "url": "https://github.com/IEvangelist/asciinema.ext/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "Asciinema",
      "properties": {
        "asciinema.maxArtifactSizeMB": {
          "type": "number",
          "default": 250,
          "minimum": 1,
          "maximum": 4096,
          "description": "Maximum compressed size (in MB) of a workflow artifact that the GitHub Artifacts Explorer command will download without prompting. Larger selections are still allowed after a confirmation dialog."
        },
        "asciinema.maxArtifactExtractedMB": {
          "type": "number",
          "default": 2048,
          "minimum": 1,
          "maximum": 16384,
          "description": "Maximum total uncompressed size (in MB) of artifact contents written to disk during extraction."
        },
        "asciinema.maxArtifactEntryCount": {
          "type": "number",
          "default": 250000,
          "minimum": 100,
          "maximum": 2000000,
          "description": "Maximum number of files allowed inside a downloaded artifact zip. Protects against zip-bomb-style archives."
        },
        "asciinema.maxArtifactEntrySizeMB": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 8192,
          "description": "Maximum uncompressed size (in MB) of any single file inside an artifact zip."
        }
      }
    },
    "languages": [
      {
        "id": "asciicast",
        "extensions": [
          ".cast"
        ],
        "aliases": [
          "Asciicast",
          "asciinema"
        ],
        "icon": {
          "light": "media/asciinema-icon.svg",
          "dark": "media/asciinema-icon.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "asciinema.castPreview",
        "displayName": "Asciinema Player",
        "selector": [
          {
            "filenamePattern": "*.cast"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "asciinema.openAsText",
        "title": "Open as Text",
        "category": "Asciinema",
        "icon": "$(file-code)"
      },
      {
        "command": "asciinema.openFromPullRequest",
        "title": "Artifacts Explorer",
        "category": "GitHub",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "asciinema.openAsText",
          "when": "activeCustomEditorId == asciinema.castPreview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src/**/*.ts",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/remote/__tests__/*.test.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "asciinema-player": "^3.15.0",
    "jszip": "^3.10.1"
  }
}
